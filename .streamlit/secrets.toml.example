# Copy this file to  .streamlit/secrets.toml  (locally) or paste its contents
# into the "Secrets" box of your Streamlit Community Cloud app settings.
#
# Each key/value under [credentials] is one login (username = "password").
# If no credentials are configured, the app falls back to a demo account
# (username: demo · password: demo).

[credentials]
afeez = "change-this-password"
guest = "another-password"
